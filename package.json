{
  "name": "openclaw-trading-stack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev:broker-executor": "pnpm --filter @apps/broker-executor run dev",
    "report:daily": "node apps/openclaw-config/scripts/scheduled-report.mjs daily prepare",
    "report:weekly": "node apps/openclaw-config/scripts/scheduled-report.mjs weekly prepare",
    "report:daily:prepare": "node apps/openclaw-config/scripts/scheduled-report.mjs daily prepare",
    "report:daily:deliver": "node apps/openclaw-config/scripts/scheduled-report.mjs daily deliver",
    "report:daily:run": "node apps/openclaw-config/scripts/scheduled-report.mjs daily run",
    "report:weekly:prepare": "node apps/openclaw-config/scripts/scheduled-report.mjs weekly prepare",
    "report:weekly:deliver": "node apps/openclaw-config/scripts/scheduled-report.mjs weekly deliver",
    "report:weekly:run": "node apps/openclaw-config/scripts/scheduled-report.mjs weekly run",
    "report:scheduled": "node apps/openclaw-config/scripts/scheduled-report.mjs",
    "stock-analysis:targets": "node apps/openclaw-config/scripts/stock-analysis.mjs targets",
    "stock-analysis:list-targets": "node apps/openclaw-config/scripts/stock-analysis.mjs list-targets",
    "stock-analysis:prepare": "node apps/openclaw-config/scripts/stock-analysis.mjs prepare",
    "stock-analysis:run": "node apps/openclaw-config/scripts/stock-analysis.mjs run",
    "stock-analysis:scheduled": "node apps/openclaw-config/scripts/stock-analysis.mjs scheduled",
    "official-paper:poll": "node apps/openclaw-config/scripts/official-paper-monitor.mjs poll",
    "official-paper:pnl": "node apps/openclaw-config/scripts/official-paper-monitor.mjs pnl",
    "official-paper:snapshot": "node apps/openclaw-config/scripts/official-paper-monitor.mjs snapshot",
    "alerts:poll": "node apps/openclaw-config/scripts/market-alerts-poll.mjs",
    "feishu:authorize-user": "node apps/openclaw-config/scripts/authorize-feishu-user.mjs",
    "feishu:user-plugin:oauth": "node apps/openclaw-config/scripts/setup-feishu-user-auth.mjs oauth",
    "feishu:user-plugin:status": "node apps/openclaw-config/scripts/setup-feishu-user-auth.mjs status",
    "longbridge:snapshot": "node apps/openclaw-config/scripts/longbridge-account-snapshot.mjs",
    "longbridge:quote": "node apps/openclaw-config/scripts/longbridge-quote.mjs",
    "longbridge:reconcile-official-paper": "node apps/openclaw-config/scripts/reconcile-official-paper-orders.mjs",
    "paper:submit-official-equity": "node apps/openclaw-config/scripts/submit-official-paper-equity-order.mjs",
    "openclaw:cron:install": "node apps/openclaw-config/scripts/install-openclaw-cron.mjs",
    "openclaw:runtime:doctor": "node apps/openclaw-config/scripts/openclaw-runtime-doctor.mjs",
    "launchd:install-system": "bash apps/openclaw-config/scripts/install-system-daemons.sh",
    "launchd:install-user": "node apps/openclaw-config/scripts/install-user-schedules.mjs",
    "backup:daily": "node apps/openclaw-config/scripts/backup-trading-data.mjs",
    "backup:restore": "node apps/openclaw-config/scripts/restore-trading-data.mjs",
    "test": "vitest run",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
