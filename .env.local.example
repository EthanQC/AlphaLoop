# AlphaLoop local environment template.
#
# Copy this file to `.env.local` (gitignored, never commit it) and fill in real
# values. Every key below is read from `.env.local` by at least one of:
#   packages/shared-types/src/runtime.ts
#   apps/openclaw-config/scripts/render-openclaw-config.mjs
#   apps/openclaw-config/scripts/setup-feishu-user-auth.mjs
#   apps/openclaw-config/scripts/authorize-feishu-user.mjs
#   apps/openclaw-config/scripts/run-feishu-user-plugin.mjs
#   apps/openclaw-config/scripts/report-data.mjs
#   apps/openclaw-config/scripts/_longbridge.mjs
#   apps/openclaw-config/scripts/news-sources.mjs
# See docs/superpowers/specs/secrets-inventory.md for storage/rotation notes.
#
# No real values live in this file. "replace_me" marks required secrets.

# --- Longbridge broker credentials -----------------------------------------
# Required. The official Longbridge OpenAPI CLI reads these three directly
# from the process environment (this repo only passes them through).
LONGBRIDGE_APP_KEY=replace_me
LONGBRIDGE_APP_SECRET=replace_me
LONGBRIDGE_ACCESS_TOKEN=replace_me
# Optional fallback for LONGBRIDGE_ACCESS_TOKEN (checked in this order:
# LONGBRIDGE_ACCESS_TOKEN, then LONGPORT_ACCESS_TOKEN).
LONGPORT_ACCESS_TOKEN=
# Optional: path to a CLI-issued token file, used only when neither access
# token above is set. Defaults to the newest file under
# ~/.longbridge/openapi/tokens/.
LONGBRIDGE_OPENAPI_TOKEN_PATH=

# --- Longbridge execution safety switches -----------------------------------
# All three must hold these exact values for official paper execution to run.
# Live execution never turns on from this flag alone (see AGENTS.md Hard Rules).
LONGBRIDGE_ACCOUNT_MODE=paper
LONGBRIDGE_OFFICIAL_PAPER_ENABLED=true
ALLOW_LIVE_EXECUTION=false

# --- Longbridge CLI read tuning (optional; defaults shown in comments) -----
LONGBRIDGE_CLI_PATH=
# Default: ~/.local/bin/longbridge
LONGBRIDGE_CLI_TIMEOUT_MS=
# Default: 45000 (ms per CLI subprocess call)
LONGBRIDGE_READ_RETRY_ATTEMPTS=
# Default: 4 (retry attempts for transient read errors)
LONGBRIDGE_READ_RETRY_BASE_MS=
# Default: 1200 (base backoff ms, doubles per attempt with jitter)

# --- OpenClaw gateway --------------------------------------------------------
OPENCLAW_GATEWAY_PORT=18789
# Required for a stable token across restarts; auto-generates a random one if
# left unset (which invalidates any previously paired client).
OPENCLAW_GATEWAY_TOKEN=replace_me

# --- Feishu bot channel (main account) --------------------------------------
# Required to enable the Feishu channel at all (both must be non-empty).
FEISHU_APP_ID=replace_me
FEISHU_APP_SECRET=replace_me
# "feishu" (feishu.cn) or "lark" (larksuite.com)
FEISHU_DOMAIN=feishu
FEISHU_BOT_NAME="Trading Copilot"
# Optional: event-subscription verification token from the Feishu app console.
FEISHU_VERIFICATION_TOKEN=
# Optional: comma-separated allowlisted user open_ids for direct messages.
FEISHU_ALLOW_FROM=
# Optional: "allowlist" or "pairing". Defaults to "allowlist" once
# FEISHU_ALLOW_FROM has at least one entry, otherwise "pairing".
FEISHU_DM_POLICY=
# Optional: comma-separated allowlisted group chat ids.
FEISHU_GROUP_ALLOW_FROM=
# Require an @mention in group chats before the bot responds.
FEISHU_REQUIRE_MENTION=true

# --- Feishu user-plugin (personal automation, OAuth-based) ------------------
# Local OAuth callback port used by `setup-feishu-user-auth.mjs oauth`.
FEISHU_USER_PLUGIN_OAUTH_PORT=9997
# Target group display name for user-plugin report delivery.
FEISHU_USER_PLUGIN_GROUP_NAME="炒股这一块"
# Target bot chat id for report delivery via the user-plugin.
FEISHU_USER_PLUGIN_BOT_CHAT_ID=
# Target user (P2P) chat id for user-plugin delivery.
FEISHU_USER_PLUGIN_CHAT_ID=
# Fallback chat id, checked alongside FEISHU_USER_PLUGIN_BOT_CHAT_ID.
FEISHU_NOTIFY_CHAT_ID=
# Feishu web session cookie string, imported via
# `setup-feishu-user-auth.mjs cookie-from-state <playwright-storage-state.json>`.
LARK_COOKIE=
# Optional: default to FEISHU_APP_ID / FEISHU_APP_SECRET above if left unset.
LARK_APP_ID=
LARK_APP_SECRET=
# Written automatically by the OAuth flow (`setup-feishu-user-auth.mjs oauth`).
# Only needed for P2P/user chat reading, not bot report delivery.
LARK_USER_ACCESS_TOKEN=
LARK_USER_REFRESH_TOKEN=
LARK_UAT_SCOPE=
LARK_UAT_EXPIRES=

# --- Phase 4 news engine: L1 source clients --------------------------------
# Optional. Finnhub company-news API key (https://finnhub.io); when unset,
# news-sources.mjs's collectL1News skips Finnhub entirely (sourceHealth
# 'skipped_no_key') instead of erroring - the report still runs on the
# remaining sources. Sent as the `X-Finnhub-Token` header; never logged
# unredacted (see news-sources.mjs's redactSecret).
FINNHUB_API_KEY=
# Optional. Base URL of a locally-run RSSHub instance used for the Chinese-
# language wire routes (财联社/华尔街见闻/格隆汇). Default when unset:
# http://127.0.0.1:1200 (a local Docker RSSHub container - see
# apps/openclaw-config/launchd, P10 deployment). RSSHub itself carries no
# credential of any kind.
RSSHUB_BASE_URL=

# --- Reserved for future phases (leave unset; do not enable yet) -----------
# MEMORYD_DATA_ROOT=              # Phase 7+: memoryd platform instance data root
